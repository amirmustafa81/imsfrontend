NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api
# Login bypass is intentionally disabled by default.
# For local UI walkthroughs, set these flags to true temporarily.
NEXT_PUBLIC_ALLOW_ANONYMOUS_ACCESS=false
NEXT_PUBLIC_DISABLE_AUTH=false
NEXT_PUBLIC_FORCE_DISABLE_AUTH=0
NEXT_PUBLIC_TEMP_DISABLE_AUTH=false
NEXT_PUBLIC_GUEST_MODE=false
