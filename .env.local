NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api
# TEMP: keep login disabled for now (guest mode) so app opens without login.
NEXT_PUBLIC_ALLOW_ANONYMOUS_ACCESS=true
# TEMP: keep login bypass enabled for demo/dev. Set to false to re-enable auth.
NEXT_PUBLIC_DISABLE_AUTH=true
NEXT_PUBLIC_FORCE_DISABLE_AUTH=1
NEXT_PUBLIC_TEMP_DISABLE_AUTH=true
